<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E49393"
    android:fillViewport="true"
    tools:context=".MeditationActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/aclonica"
            android:text="Meditation"
            android:background="@drawable/shape2"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:padding="8dp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:src="@drawable/meditate"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:scaleType="fitCenter"/>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#C89638">

            <TextView
                android:id="@+id/recipesText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The (Shrinking) Amygdala\n\n1. Meditation doesn't just (calm you down); it physically changes the brain's structure.\nConsistent meditation (about 8 weeks) has been shown to decrease the gray-matter density in the amygdala, the region of the brain responsible for the (fight or flight) response.\n\nNeuroplasticity and The Prefrontal Cortex\n\nWhile the (fear center) shrinks, the (logical center) grows.\nMeditation strengthens the Prefrontal Cortex, which is responsible for executive functions like concentration, decision-making, and awareness."
                android:textSize="17sp"
                android:lineSpacingExtra="4dp"
                android:padding="20dp"
                android:textColor="#212121"
                android:fontFamily="@font/amarante"/>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>